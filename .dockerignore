# 前端项目核心忽略项
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock

# 构建产物（本地构建的产物，Docker内会重新构建，无需传入）
dist/
build/
storybook-static/
apps/**/dist/
apps/**/build/
apps/**/storybook-static/
apps/**/node_modules/
# 系统/编辑器缓存文件
.DS_Store
*.swp
*.swo
.vscode/
.idea/
.git/
.npm/
.pnpm-store/

# 日志/临时文件
*.log
tmp/
temp/

# 环境配置文件（无需传入Docker）
.env
.env.*
!env.example

# 其他无用文件
README.md
CHANGELOG.md