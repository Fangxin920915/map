{
  "name": "gdu-gl",
  "private": true,
  "version": "0.1.9",
  "scripts": {
    "commit": "git-cz",
    "start:storybook": "pnpm --filter @gdu-gl/docs dev:storybook",
    "start:docs": "pnpm --filter @gdu-gl/docs dev:docs",
    "publish:pkg": "node scripts/publish.mjs",
    "build": "turbo build:modules",
    "clean": "node scripts/clean-node-module.mjs",
    "clean:modules": "node scripts/clean-node-module.mjs all",
    "lint": "lint-staged --allow-empty",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.18.3",
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@stylistic/stylelint-config": "2.0.0",
    "@stylistic/stylelint-plugin": "3.1.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "chalk": "^5.6.2",
    "commitizen": "4.3.1",
    "cz-git": "1.11.0",
    "eslint": "8.57.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-airbnb-typescript": "18.0.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-define-config": "2.1.0",
    "eslint-plugin-html": "8.1.2",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-prettier": "5.2.2",
    "eslint-plugin-storybook": "10.2.0",
    "eslint-plugin-vue": "9.32.0",
    "husky": "9.1.7",
    "lint-staged": "15.4.1",
    "playwright": "^1.54.2",
    "postcss-html": "1.8.0",
    "prettier": "3.4.2",
    "prettier-eslint": "16.3.0",
    "rimraf": "6.0.1",
    "sass": "1.83.4",
    "standard-version": "^9.5.0",
    "stylelint": "16.23.0",
    "stylelint-config-recess-order": "5.1.1",
    "stylelint-config-recommended-vue": "1.5.0",
    "stylelint-config-standard-scss": "14.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "4.19.2",
    "turbo": "2.5.4",
    "typescript": "5.8.3",
    "vite": "7.3.0",
    "vite-plugin-eslint": "1.8.1",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "9.4.3",
    "vue-tsc": "3.1.8"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "dependencies": {
    "lodash-es": "^4.17.21"
  },
  "pnpm": {
    "overrides": {
      "@luma.gl/shadertools": "9.1.5",
      "@luma.gl/constants": "9.1.5",
      "@luma.gl/core": "9.1.5",
      "@luma.gl/engine": "9.1.5",
      "@luma.gl/gltf": "9.1.5",
      "@luma.gl/webgl": "9.1.5",
      "@cesium/engine": "22.3.0",
      "@cesium/widgets": "14.3.0"
    }
  }
}
